// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String?  @unique
  emailVerified  DateTime?
  password       String?
  image          String?
  accounts       Account[]
  sessions       Session[]
  userNumbers    UserNumber[]
  assistants     Assistant[]
  contacts       Contact[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires   DateTime

  @@unique([identifier, token])
}

model UserNumber {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  number    String
  label     String?
  purpose   String
  phoneNumberId String?
  assistant Assistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  assistantId String
  createdAt DateTime @default(now())
}

model Assistant {
  id               String   @id @default(cuid())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  name             String
  description      String
  firstMessage     String?
  vapiAssistantId  String?
  phoneNumbers     UserNumber[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  locationId       String
  contacts         Contact[]
  location         Locations @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model Contact {
  id            String        @id @default(cuid())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
  assistant     Assistant     @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  assistantId   String
  name          String
  phoneNumber   String
  email         String?
  company       String?
  schedules     Schedule[]
  conversations Conversation[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  @@unique([phoneNumber, assistantId]) 
}

model Conversation {
  callId       String?   @unique
  id           String   @id @default(cuid())
  contact      Contact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId    String?
  phoneNumber  String
  duration     Int?     // in seconds
  status       String   // "completed", "missed", "in-progress"
  transcript   String?
  recordingUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  messages     Json?
  phoneNumberId String?
  summary       String?
  type          String  @default("inboundPhoneCall")
}

model Locations {
  id      String   @id @default(cuid())
  address String    
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assistants Assistant[]
}
model Schedule {
  id          String    @id @default(cuid())
  contact     Contact   @relation(fields: [contactId], references: [id])
  contactId   String
  scheduleDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
model Lead {
  id          String   @id @default(cuid())
  phoneNumber String
  callId      String?   @unique
  status      String    @default("PENDING") // values: PENDING | IN_PROGRESS | ENDED | FAILED
  retries     Int       @default(0)
  nextCallAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
